{
    "name": "btlz-test",
    "version": "1.0.0",
    "description": "WB tariffs sync service: fetches box tariffs from Wildberries API, stores in PostgreSQL, syncs to Google Sheets",
    "main": "app.js",
    "type": "module",
    "scripts": {
        "dev": "nodemon --watch src --ext ts --exec tsx src/app.ts",
        "watch:build": "tsc --build --force --verbose --watch",
        "knex:dev": "tsx src/utils/knex.ts",
        "build": "tsc --allowJs",
        "start": "node dist/app.js",
        "knex": "node dist/utils/knex.js",
        "tsc:check": "tsc --allowJs --noEmit",
        "prettier": "prettier --config .prettierrc.json src/**/*.js --check",
        "prettier-format": "prettier --config .prettierrc.json src/**/*.js --write",
        "eslint": "eslint",
        "eslint-fix": "eslint --fix",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:e2e": "vitest run --config vitest.e2e.config.ts"
    },
    "imports": {
        "#*": [
            "./dist/*",
            "./src/*"
        ]
    },
    "_moduleAliases": {
        "#": "src"
    },
    "author": "lucard17",
    "license": "ISC",
    "dependencies": {
        "commander": "^13.1.0",
        "dotenv": "^16.3.1",
        "express": "^5.2.1",
        "express-rate-limit": "^8.3.0",
        "googleapis": "^144.0.0",
        "helmet": "^8.1.0",
        "knex": "^3.0.1",
        "log4js": "^6.9.1",
        "node-cron": "^4.2.1",
        "pg": "^8.11.3",
        "zod": "^3.23.8"
    },
    "devDependencies": {
        "@types/express": "^5.0.6",
        "@types/express-rate-limit": "^5.1.3",
        "@types/node-cron": "^3.0.11",
        "@types/pg": "^8.11.10",
        "@types/supertest": "^7.2.0",
        "eslint": "^9.15.0",
        "eslint-config-prettier": "^9.1.0",
        "eslint-plugin-prettier": "^5.2.1",
        "eslint-plugin-unused-imports": "^4.1.4",
        "nodemon": "^3.0.2",
        "prettier": "^3.3.3",
        "supertest": "^7.2.2",
        "tsx": "^4.19.0",
        "typescript": "^5.7.3",
        "vite-tsconfig-paths": "^6.1.1",
        "vitest": "^4.0.18"
    }
}
